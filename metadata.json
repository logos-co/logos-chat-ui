{
  "name": "chat_ui",
  "version": "0.1.0",
  "description": "Chat App for Logos - Private messaging interface",
  "author": "Logos Core Team",
  "type": "ui",
  "main": "chat_ui",
  "dependencies": ["chat_module"],
  "category": "chat",
  "build": {
    "type": "cmake",
    "files": [
